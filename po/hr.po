#: data/louper.desktop.in:2 data/louper.metainfo.xml.in:10
msgid "Louper"
msgstr "Louper"

#: data/louper.desktop.in:3
msgid "Text Magnification App"
msgstr "Aplikacija za povećanje teksta"

#: data/louper.desktop.in:4 data/louper.metainfo.xml.in:11
msgid "Magnify the selected text"
msgstr "Povećaj odabrani tekst"

#: data/louper.desktop.in:10
msgid "Zoom;Copy;"
msgstr "Zumiraj;Kopiraj;"

#: data/louper.metainfo.xml.in:13
msgid "A text magnification app that helps you zoom the selected text."
msgstr "Aplikacija za povećanje teksta koja pomaže zumirati odabrani tekst."

#: data/louper.metainfo.xml.in:16
msgid ""
"Select the text you want to magnify and just launch the app! The app shows "
"the selected text in huge size."
msgstr ""
"Odaberi tekst koji želi povećati i pokreni aplikaciju! Aplikacija prikazuje "
"odabrani tekst u velikoj veličini."

#: data/louper.metainfo.xml.in:19
msgid "Other features include:"
msgstr "Ostale funkcije uključuju:"

#: data/louper.metainfo.xml.in:23
msgid ""
"Select some part of the magnified text and press Ctrl+C or perform secondary "
"click to copy it"
msgstr ""
"Odaberi neki dio povećanog teksta i pritisni Ctrl+C ili izvedi sekundarni "
"klik za kopiranje"

#: data/louper.metainfo.xml.in:24
msgid "Press Esc or Ctrl+Q or unfocus the window to close the app"
msgstr "Pritisni Esc ili Ctrl+Q ili odmakni prozor za zatvaranje aplikacije"

#: data/louper.metainfo.xml.in:30
msgid "Zoom in what you like to read"
msgstr "Zumiraj tekst koji želiš čitati"

#. developer_name has deprecated since AppStream 1.0
#: data/louper.metainfo.xml.in:54
msgid "Ryo Nakano"
msgstr ""

#: src/Application.vala:13
msgid "Keep the app window open when unfocused"
msgstr "Zadrži prozor aplikacije otvorenim kada nije fokusiran"

#: src/Application.vala:17
msgid "The text to zoom in; the clipboard is used if none specified"
msgstr ""
"Tekst za zumiranje; Međuspremnik se koristi ako nijedan nije specificiran"
