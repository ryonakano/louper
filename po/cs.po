#: data/louper.desktop.in:2
msgid "Louper"
msgstr "Louper"

#: data/louper.desktop.in:3
msgid "Text Magnification App"
msgstr "Aplikace pro zvětšování textu"

#: data/louper.desktop.in:4 data/louper.metainfo.xml.in:11
msgid "Magnify the selected text"
msgstr "Zvětšit označený text"

#: data/louper.desktop.in:10
msgid "Zoom;Copy;"
msgstr "Přiblížit;Zkopírovat;"

#: data/louper.metainfo.xml.in:13
msgid "A text magnification app that helps you zoom the selected text."
msgstr "Aplikace pro zvětšování textu která pomáhá přibližovat označený text."

#: data/louper.metainfo.xml.in:16
msgid ""
"Select the text you want to magnify and just launch the app! The app shows "
"the selected text in huge size."
msgstr ""
"Vyberte text který chcete zvětšit a prostě jen spusťte aplikaci! Ta ho "
"zobrazí jako obrovský."

#: data/louper.metainfo.xml.in:19
msgid "Other features include:"
msgstr "Mezi ostatní funkce patří:"

#: data/louper.metainfo.xml.in:23
msgid ""
"Select some part of the magnified text and press Ctrl+C or perform secondary "
"click to copy it"
msgstr ""
"Vyberte nějakou část zvětšeného textu a stiskněte Ctrl+C nebo klikněte "
"prostředním tlačítkem myši a zkopírujte ho tak"

#: data/louper.metainfo.xml.in:24
msgid "Press Esc or Ctrl+Q or unfocus the window to close the app"
msgstr ""
"Stiskněte Esc nebo Ctrl+Q nebo zrušte zaměření okna (kliknutí mimo) a "
"aplikace se zavře"

#: data/louper.metainfo.xml.in:30
msgid "Zoom in what you like to read"
msgstr "Přibližte si co byste chtěli přečíst"

#: src/louper-application.c:31
msgid "Keep the app window open when unfocused"
msgstr "Ponechat okno aplikace otevřené i když přijde o zaměření"

#: src/louper-application.c:35
msgid "The text to zoom in; the clipboard is used if none specified"
msgstr ""
"Text pro přiblížení (pokud není určen žádný, je přiblížen obsah schránky)"

#: src/louper-application.c:35
msgid "TEXT"
msgstr "TEXT"
